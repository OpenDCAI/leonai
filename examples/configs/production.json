{
  "temperature": 0.3,
  "enable_audit_log": true,
  "allowed_extensions": ["py", "js", "ts", "json", "yaml"],
  "block_dangerous_commands": true,
  "block_network_commands": true,
  "tools": {
    "filesystem": {
      "enabled": true,
      "tools": {
        "read_file": {
          "enabled": true,
          "max_file_size": 5242880
        },
        "write_file": false,
        "edit_file": false,
        "list_dir": true
      }
    },
    "search": {
      "enabled": true,
      "max_results": 30
    },
    "command": {
      "enabled": false
    },
    "web": {
      "enabled": false
    }
  },
  "system_prompt": "You are working in a production environment. Be extremely careful with any suggestions. Always prioritize safety and stability."
}
